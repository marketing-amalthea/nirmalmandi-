# ─────────────────────────────────────────────────────────────────────────────
# NirmalMandi — Environment Variables Reference
# Copy relevant vars to each service on Railway. Vercel vars go in Vercel dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon — neon.tech, free tier) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/nirmalmandi?sslmode=require

# ── Redis (Upstash — upstash.com, free tier) ─────────────────────────────────
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# ── JWT (shared across all services) ─────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string
# For RS256 (optional, more secure):
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── OTP / SMS — Pick ONE ──────────────────────────────────────────────────────
# MSG91 (recommended for India, msg91.com):
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-otp-template-id
MSG91_SENDER_ID=NRMNDM
# OR Twilio (global, twilio.com):
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Payments (Razorpay TEST mode — razorpay.com) ─────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── AI (Anthropic — console.anthropic.com) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# ── File Storage (Cloudinary free tier, cloudinary.com) ──────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Push Notifications (Firebase — firebase.google.com, free) ────────────────
FIREBASE_PROJECT_ID=nirmalmandi
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@nirmalmandi.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"

# ── Internal service secret (set SAME value on ALL services) ─────────────────
INTERNAL_SERVICE_SECRET=replace-with-64-char-random-hex

# ── Platform ─────────────────────────────────────────────────────────────────
PLATFORM_GSTIN=27AABCA1234A1Z5
NODE_ENV=production
PORT=3000

# ── Vercel env vars (web + admin apps) — fill after Railway deployment ────────
AUTH_SERVICE_URL=https://auth-service-XXXX.up.railway.app
INVENTORY_SERVICE_URL=https://inventory-service-XXXX.up.railway.app
ORDER_SERVICE_URL=https://order-service-XXXX.up.railway.app
SEARCH_SERVICE_URL=https://search-service-XXXX.up.railway.app
PAYMENT_SERVICE_URL=https://payment-service-XXXX.up.railway.app
NOTIFICATION_SERVICE_URL=https://notification-service-XXXX.up.railway.app
LOGISTICS_SERVICE_URL=https://logistics-service-XXXX.up.railway.app
ANALYTICS_SERVICE_URL=https://analytics-service-XXXX.up.railway.app
INVOICE_SERVICE_URL=https://invoice-service-XXXX.up.railway.app
DISPUTE_SERVICE_URL=https://dispute-service-XXXX.up.railway.app
AI_SERVICE_URL=https://ai-service-XXXX.up.railway.app

# ── Optional (skip for MVP) ──────────────────────────────────────────────────
DELHIVERY_TOKEN=
KARZA_API_KEY=
